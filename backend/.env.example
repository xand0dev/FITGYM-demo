# Скопіюй цей файл у .env і заповни значення перед запуском у продакшні

# Django
SECRET_KEY=your-very-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS — перелік через кому
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Database (якщо порожньо — використовується SQLite)
DATABASE_URL=postgresql://fitgym_user:password@localhost:5432/fitgym_db

